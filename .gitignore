# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env.local

# ── Environment / secrets ──────────────────────────────────────────────────────
.env
*.env
!.env.example        # keep the example template if one exists

# ── Database files ─────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Uploaded files (runtime data, not source) ──────────────────────────────────
uploads/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
server.log
logs/

# ── Test / coverage artefacts ─────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.coveragerc

# ── Type-checker / linter caches ──────────────────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── Build / distribution ──────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── IDEs & editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Alembic ───────────────────────────────────────────────────────────────────
# Keep migrations/ tracked; ignore only the generated env artefact if present
alembic/versions/__pycache__/

# ── Temporary / scratch files ─────────────────────────────────────────────────
*.tmp
*.bak
*.orig
