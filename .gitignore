# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
.Python

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env.local

# ── Environment / secrets ──────────────────────────────────────────────────────
.env
*.env
!.env.example        # keep the example template if one exists

# ── Database files ─────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Uploaded files (runtime data, not source) ──────────────────────────────────
uploads/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
server.log
logs/

# ── Test / coverage artefacts ─────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.coveragerc

# ── Generated test data ────────────────────────────────────────────────────────
test_docs/
test_docs_new/
# Scratch test files (not part of test suite)
_test3.py
test_unified_endpoint.py

# ── Type-checker / linter caches ──────────────────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── Build / distribution ──────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── IDEs & editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Alembic ───────────────────────────────────────────────────────────────────
# Keep migrations/ tracked; ignore only the generated env artefact if present
alembic/versions/__pycache__/

# ── Frontend (Node.js / React / Vite) ─────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
.vite/
dist/
.next/
out/
package-lock.json
yarn.lock

# ── Docker artefacts ──────────────────────────────────────────────────────────
.dockerignore

# ── Temporary / scratch files ─────────────────────────────────────────────────
*.tmp
*.bak
*.orig
