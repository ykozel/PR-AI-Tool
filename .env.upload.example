# Environment Variables - File Upload Configuration

# For use in .env file during development and production

# ============================================================================
# FILE UPLOAD SETTINGS
# ============================================================================

# Maximum file size for uploads in MB
MAX_FILE_SIZE=50

# Directory where uploaded PDF files are temporarily stored
# Linux/Mac: /tmp/uploads or /var/uploads
# Windows: C:\temp\uploads or %TEMP%\uploads
TEMP_UPLOAD_DIR=/tmp/uploads

# Allowed file types (comma-separated, for future extension)
ALLOWED_FILE_TYPES=pdf

# ============================================================================
# PDF PROCESSING SETTINGS
# ============================================================================

# Tesseract OCR executable path (required for OCR functionality)
# Linux/Mac: /usr/bin/tesseract (usually auto-detected)
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# Leave empty to auto-detect
TESSERACT_PATH=

# OCR Language for text extraction (default: eng for English)
# Supports multiple languages, comma-separated
# Examples: eng, fra, deu, spa, chi_sim
OCR_LANGUAGE=eng

# Enable debugging for PDF processing
PDF_DEBUG=false

# ============================================================================
# DATABASE SETTINGS
# ============================================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/prprofile

# Enable SQL query logging (useful for debugging)
DATABASE_ECHO=false

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Application name
APP_NAME=PR Profile

# Debug mode (set to false in production)
DEBUG=false

# Secret key for security (change this in production!)
SECRET_KEY=your-secret-key-change-in-production

# ============================================================================
# CORS SETTINGS
# ============================================================================

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# ============================================================================
# AI/ML SETTINGS
# ============================================================================

# OpenAI API key (optional, for future AI integration)
OPENAI_API_KEY=sk-... 

# AI Model to use
AI_MODEL=gpt-4

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# Access token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiration in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# EMAIL SETTINGS (Optional)
# ============================================================================

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ============================================================================
# LOGGING SETTINGS
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (optional)
LOG_FILE=/var/log/pr-profile/app.log

# ============================================================================
# MONITORING & PERFORMANCE
# ============================================================================

# Enable request logging
LOG_REQUESTS=true

# Request timeout in seconds
REQUEST_TIMEOUT=30

# Maximum concurrent uploads
MAX_CONCURRENT_UPLOADS=10

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Enable auto-reload on file changes
RELOAD=true

# Number of uvicorn workers
WORKERS=1
